{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "$ref": "#/definitions/MotionFile",
  "definitions": {
    "MotionFile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "motion": {
          "$ref": "#/definitions/Motion"
        }
      },
      "required": [
        "motion"
      ],
      "title": "MotionFile"
    },
    "Motion": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z][a-zA-Z0-9]*$": {
          "$ref": "#/definitions/TokenCategory"
        }
      },
      "additionalProperties": false,
      "title": "Motion"
    },
    "TokenCategory": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z][a-zA-Z0-9]*$": {
          "$ref": "#/definitions/MotionToken"
        }
      },
      "additionalProperties": false,
      "title": "TokenCategory"
    },
    "MotionToken": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "value": {
              "type": "string",
              "pattern": "^\\d+ms$"
            },
            "type": {
              "type": "string",
              "enum": ["duration"]
            },
            "description": {
              "type": "string"
            }
          },
          "required": [
            "value",
            "type"
          ],
          "additionalProperties": false,
          "title": "DurationToken"
        },
        {
          "type": "object",
          "properties": {
            "value": {
              "type": "string",
              "pattern": "^cubic-bezier\\(.+\\)$"
            },
            "type": {
              "type": "string",
              "enum": ["cubicBezier"]
            },
            "description": {
              "type": "string"
            }
          },
          "required": [
            "value",
            "type"
          ],
          "additionalProperties": false,
          "title": "CubicBezierToken"
        }
      ],
      "title": "MotionToken"
    }
  }
}
