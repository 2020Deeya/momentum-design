{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "$ref": "#/definitions/MotionFile",
  "definitions": {
    "MotionFile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "motion": {
          "$ref": "#/definitions/Motion"
        }
      },
      "required": [
        "motion"
      ],
      "title": "MotionFile"
    },
    "Motion": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z][a-zA-Z0-9]*$": {
          "$ref": "#/definitions/TokenCategory"
        }
      },
      "additionalProperties": false,
      "title": "Motion"
    },
    "TokenCategory": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z][a-zA-Z0-9]*$": {
          "$ref": "#/definitions/MotionToken"
        }
      },
      "additionalProperties": false,
      "title": "TokenCategory"
    },
    "MotionToken": {
      "type": "object",
      "properties": {
        "value": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      },
      "required": [
        "value",
        "type"
      ],
      "additionalProperties": false,
      "title": "MotionToken"
    }
  }
}
